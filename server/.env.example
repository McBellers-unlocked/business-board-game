# ---- Core ----
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:4000
CLIENT_ORIGIN=http://localhost:5173

# ---- Database (local dev defaults match docker-compose) ----
DATABASE_URL=postgres://dcl:dcl_dev_password@localhost:5432/dcl
PGSSL=false

# ---- Auth ----
# Shared secret for the lightweight team-member JWT.
TEAM_JWT_SECRET=change-me-local-dev-only
# Dev-mode facilitator auth: when true, skips Cognito and uses local password storage in `facilitators.password_hash`.
AUTH_DEV_MODE=true

# ---- AWS Cognito (used when AUTH_DEV_MODE=false) ----
AWS_REGION=eu-west-2
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# ---- S3 (PDF exports) ----
S3_EXPORTS_BUCKET=
